# Email Configuration
# Gmail account for sending prayer emails
SENDER_EMAIL=your_gmail_account@gmail.com
# Gmail App Password (required with 2FA enabled)
SENDER_PASSWORD=your_gmail_app_password_here

# Supabase Configuration  
# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key (for admin operations)
SUPABASE_KEY=your_service_role_key_here

# Database Configuration
# PostgreSQL connection string for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# Application Configuration
# Data storage mode: 'local' for JSON files, 'database' for Supabase
DATA_MODE=database

# API Configuration  
# Optional: API key for endpoint authentication
API_KEY=your_api_key_here

# Email Configuration (Recipients)
# Default recipient for prayer emails
DEFAULT_RECIPIENT=recipient@example.com